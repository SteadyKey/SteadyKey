{
  "manifest_version": 3,
  "name": "SteadyKey",
  "version": "1.0.0",
  "description": "SteadyKey — Local-only password vault using PIN + MachineKey + AES-256",
  "permissions": ["storage"],
  "background": {
    "service_worker": "dist/background.js"
  },
  "action": {
    "default_popup": "dist/ui/popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
